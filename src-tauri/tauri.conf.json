{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "node scripts/prepare-tauri-assets.mjs",
    "beforeDevCommand": "",
    "devPath": "../",
    "distDir": "../dist-tauri",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "GitHub Widget",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.sofia.githubwidget",
      "targets": "nsis",
      "icon": [
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "GitHub Widget",
        "label": "main",
        "url": "index.html",
        "width": 780,
        "height": 400,
        "minWidth": 620,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "visible": true,
        "center": true
      }
    ]
  }
}
